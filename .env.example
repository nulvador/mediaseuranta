# Kopioi tiedostoksi .env ja täytä arvot. ÄLÄ commitoi .env-tiedostoa.

# Gemini (pakollinen analyysiä varten)
GEMINI_API_KEY=
# Malli: flash-lite on usein ruuhkautunut (503) ilmaiskäytössä.
# Jos 503-virheet toistuvat, kokeile toista mallia — eri malleilla omat kiintiönsä:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Keruu (valinnaiset)
# LOOKBACK_DAYS=5
# REPORT_DAYS=60

# Sähköposti (valinnainen — jos SMTP_HOST puuttuu, lähetys ohitetaan)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=viestinta@golf.fi
# SMTP_PASS=
# EMAIL_FROM=viestinta@golf.fi
# EMAIL_TO=viestintapaallikko@golf.fi
